# Homey Pro OAuth2 credentials (required)
HOMEY_CLIENT_ID=your-client-id-here
HOMEY_CLIENT_SECRET=your-client-secret-here
HOMEY_ADDRESS=http://192.168.1.xxx

# Claude API key (required for chat and agent mode)
ANTHROPIC_API_KEY=sk-ant-xxx

# Web server (optional)
# WEB_PORT=3000
# SESSION_SECRET=generate-a-random-string-here

# Token file path (optional, for Docker volume persistence)
# TOKEN_FILE_PATH=/app/data/tokens.json

# OAuth2 CLI callback port (optional, default: 3456)
# OAUTH_CALLBACK_PORT=3456
